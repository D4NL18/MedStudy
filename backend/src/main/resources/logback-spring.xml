<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
            <layout class="com.medstudy.backend.core.logging.MaskingPatternLayout">
                <!-- Sensitive field masking patterns -->
                <maskPattern>(?i)(password|senha)\s*[:=]\s*["']?([^"'\s,{}]+)["']?</maskPattern>
                <maskPattern>(?i)(access_token|refreshToken|token|jwt)\s*[:=]\s*["']?([^"'\s,{}]+)["']?</maskPattern>
                <maskPattern>(?i)(email)\s*[:=]\s*["']?([^"'\s,{}]+)["']?</maskPattern>
                <maskPattern>(?i)(cpf)\s*[:=]\s*["']?([^"'\s,{}]+)["']?</maskPattern>
                
                <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}</pattern>
            </layout>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
